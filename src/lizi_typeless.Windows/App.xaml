<Application x:Class="lizi_typeless.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <Color x:Key="InkColor">#17242B</Color>
        <Color x:Key="MutedColor">#65757B</Color>
        <Color x:Key="PaperColor">#F4F0E6</Color>
        <Color x:Key="PanelColor">#FFFCF5</Color>
        <Color x:Key="TealColor">#087E8B</Color>
        <Color x:Key="CoralColor">#F45B3A</Color>

        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="PaperBrush" Color="{StaticResource PaperColor}" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
        <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}" />
        <SolidColorBrush x:Key="CoralBrush" Color="{StaticResource CoralColor}" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource PaperBrush}" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TealBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E6ECE9" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>
    </Application.Resources>
</Application>
