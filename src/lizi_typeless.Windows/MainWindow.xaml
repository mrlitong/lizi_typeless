<Window x:Class="lizi_typeless.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="lizi_typeless 历史"
        Width="1120"
        Height="740"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontFamily="Bahnschrift SemiBold"
                           FontSize="30"
                           Text="lizi_typeless" />
                <TextBlock Margin="1,4,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="本地语音记录 · 双击右 Alt 开始" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="14,8"
                    VerticalAlignment="Center"
                    Background="#DCEDEA"
                    CornerRadius="18">
                <TextBlock x:Name="ServiceStatusText"
                           Foreground="{StaticResource TealBrush}"
                           FontWeight="SemiBold"
                           Text="推理服务：检查中" />
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="16" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="6,4">
                        <TextBlock FontFamily="Bahnschrift SemiBold"
                                   FontSize="18"
                                   Text="历史记录" />
                        <Button DockPanel.Dock="Right"
                                Padding="9,4"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource TealBrush}"
                                Click="RefreshButton_Click"
                                Content="刷新" />
                    </DockPanel>
                    <ListBox x:Name="SessionsList"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="SessionsList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Background="#F0ECE2" CornerRadius="10">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayTime}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="{StaticResource TealBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding StatusText}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,7,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="{Binding Summary}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="24"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DetailTitle"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="21"
                                       Text="选择一条记录" />
                            <TextBlock x:Name="DetailMeta"
                                       Margin="0,5,0,0"
                                       Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="ErrorText"
                                   Grid.Column="1"
                                   MaxWidth="320"
                                   Foreground="{StaticResource CoralBrush}"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="原始转录" />
                            <TextBox x:Name="RawTranscriptText"
                                     Grid.Row="2"
                                     Padding="14"
                                     Background="#F7F4EC"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="整理结果" />
                            <TextBox x:Name="FinalText"
                                     Grid.Row="2"
                                     Padding="14"
                                     Background="#F7F4EC"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Grid>

                    <WrapPanel Grid.Row="4" HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="PlayButton_Click"
                                Content="播放录音" />
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="CopyButton_Click"
                                Content="复制结果" />
                        <Button Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Click="DeleteButton_Click"
                                Content="删除" />
                        <Button Style="{StaticResource PrimaryButton}"
                                Click="RetryButton_Click"
                                Content="Retry" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
